# WALLE 语音对话系统配置
# 复制此文件为 .env 并修改配置

# ============================================
# LLM 配置 (OpenClaw 适配版)
# ============================================

# 使用 OpenClaw 代理
DEEPSEEK_API_KEY=openclaw-proxy
DEEPSEEK_BASE_URL=https://localhost:8081
DEEPSEEK_MODEL=openclaw-chat

# 如果使用原始 DeepSeek API，取消注释以下配置
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ============================================
# 语音识别 (STT) 配置
# ============================================

# Whisper 模型选择
# base - CPU 推荐，速度快
# small - 平衡速度和准确度
# medium - 准确度更高，需要更多资源
# large - 最高准确度，需要 GPU
WHISPER_MODEL=base

# 识别语言 (zh: 中文, en: 英文, ja: 日文, ko: 韩文等)
WHISPER_LANGUAGE=zh

# ============================================
# 语音合成 (TTS) 配置
# ============================================

# Edge-TTS 语音选择
# 中文语音:
#   zh-CN-XiaoxiaoNeural - 晓晓 (温柔女声，默认)
#   zh-CN-XiaoyiNeural - 晓伊 (活泼女声)
#   zh-CN-YunjianNeural - 云健 (沉稳男声)
#   zh-CN-YunxiNeural - 云希 (年轻男声)
#   zh-CN-YunxiaNeural - 云霞 (成熟女声)
#   zh-CN-YunyangNeural - 云扬 (专业男声)
#   zh-CN-XiaobeiNeural - 晓北 (可爱女声)
#   zh-CN-XiaoniNeural - 晓妮 (甜美女声)
TTS_VOICE=zh-CN-XiaoxiaoNeural

# 语速调整 (+10% 加快, -10% 减慢)
TTS_RATE=+0%

# ============================================
# 服务器配置
# ============================================

# 服务器监听地址
SERVER_HOST=0.0.0.0

# 服务器端口
SERVER_PORT=8000

# ============================================
# 高级配置
# ============================================

# 对话历史最大长度
MAX_HISTORY=20

# 音频采样率
AUDIO_SAMPLE_RATE=16000

# VAD (语音活动检测) 阈值
VAD_THRESHOLD=0.5

# 最小音频长度 (秒)
MIN_AUDIO_LENGTH=0.5

# 最大音频长度 (秒)
MAX_AUDIO_LENGTH=30

# ============================================
# 调试配置
# ============================================

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 是否保存音频文件
SAVE_AUDIO_FILES=false

# 音频文件保存路径
AUDIO_SAVE_PATH=./audio_cache